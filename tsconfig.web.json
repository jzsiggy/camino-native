{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "outDir": "./out",
    "rootDir": ".",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ESNext",
    "paths": {
      "@renderer/*": ["./src/renderer/src/*"],
      "@shared/*": ["./shared/*"]
    }
  },
  "include": [
    "src/renderer/src/**/*",
    "shared/**/*",
    "src/preload/*.d.ts"
  ]
}
